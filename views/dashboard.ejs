<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mes serveurs — Chell Dashboard</title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="main-content">

    <% if (error === 'noaccess') { %>
      <div class="alert alert-error"><i class="fa-solid fa-circle-xmark"></i> Vous n'avez pas accès à ce serveur.</div>
    <% } else if (error === 'noperm') { %>
      <div class="alert alert-error"><i class="fa-solid fa-circle-xmark"></i> Vous devez être administrateur sur ce serveur.</div>
    <% } %>

    <% if (isOwner && globalStats) { %>
    <div class="stats-grid mb-20">
      <div class="stat-card purple">
        <div class="stat-icon purple"><i class="fa-solid fa-server"></i></div>
        <div>
          <div class="stat-value"><%= globalStats.guildCount %></div>
          <div class="stat-label">Serveurs actifs</div>
        </div>
      </div>
      <div class="stat-card gold">
        <div class="stat-icon gold"><i class="fa-solid fa-brain"></i></div>
        <div>
          <div class="stat-value"><%= globalStats.aiConversations.toLocaleString() %></div>
          <div class="stat-label">Conversations IA</div>
        </div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon green"><i class="fa-solid fa-users"></i></div>
        <div>
          <div class="stat-value"><%= guilds.length %></div>
          <div class="stat-label">Serveurs gérés</div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="page-header">
      <h1><i class="fa-solid fa-grid-2"></i> Mes serveurs</h1>
      <p>Sélectionnez un serveur pour le configurer. Seuls vos serveurs où Chell est présente sont affichés.</p>
    </div>

    <% if (guilds.length === 0) { %>
      <div class="card">
        <div class="empty-state">
          <i class="fa-solid fa-server"></i>
          <p>Aucun serveur trouvé avec Chell et vos permissions administrateur.</p>
        </div>
      </div>
    <% } else { %>
      <div class="guild-grid">
        <% guilds.forEach(g => { %>
          <a href="/guild/<%= g.id %>" class="guild-card">
            <% if (g.icon) { %>
              <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.webp?size=128" alt="<%= g.name %>" class="guild-card-icon">
            <% } else { %>
              <div class="guild-card-placeholder"><%= g.name.charAt(0) %></div>
            <% } %>
            <div class="guild-card-name"><%= g.name %></div>
          </a>
        <% }) %>
      </div>
    <% } %>

    <% if (notIn && notIn.length > 0) { %>
      <div class="page-header mt-24">
        <h1 style="font-size:18px; color:var(--text-muted)"><i class="fa-solid fa-plus-circle"></i> Inviter Chell sur vos autres serveurs</h1>
      </div>
      <div class="guild-grid">
        <% notIn.slice(0, 6).forEach(g => { %>
          <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env?.CLIENT_ID || '1383154920231796736' %>&permissions=8&scope=bot%20applications.commands&guild_id=<%= g.id %>" target="_blank" class="guild-card" style="opacity:0.6; border-style:dashed;">
            <% if (g.icon) { %>
              <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.webp?size=128" alt="<%= g.name %>" class="guild-card-icon">
            <% } else { %>
              <div class="guild-card-placeholder" style="background: var(--bg-input); color: var(--text-muted)"><%= g.name.charAt(0) %></div>
            <% } %>
            <div class="guild-card-name"><%= g.name %></div>
            <div class="text-muted text-small mt-8"><i class="fa-solid fa-plus"></i> Inviter</div>
          </a>
        <% }) %>
      </div>
    <% } %>

  </div>
  <div id="toast"></div>
  <script src="/js/main.js"></script>
</body>
</html>
