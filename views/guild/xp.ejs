<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>XP & Levels — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'xp' }) %>
  <main class="main-content with-sidebar">
    <div class="breadcrumb"><a href="/dashboard">Mes serveurs</a><span class="sep">›</span><a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span><span class="current">XP & Levels</span></div>
    <div class="page-header"><h1><i class="fa-solid fa-trophy"></i> Système d'expérience</h1><p>Récompensez l'activité des membres avec des niveaux</p></div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-crown"></i> Top 10 Membres</div></div>
      <% if (leaderboard && leaderboard.length > 0) { %>
        <div class="leaderboard">
          <% leaderboard.forEach((member, index) => { %>
            <div class="leaderboard-item">
              <div class="leaderboard-rank rank-<%= index + 1 %>"><%= index + 1 %></div>
              <div class="leaderboard-avatar">
                <% if (member.avatar) { %>
                  <img src="<%= member.avatar %>" alt="<%= member.username %>">
                <% } else { %>
                  <div class="avatar-placeholder"><%= member.username.charAt(0).toUpperCase() %></div>
                <% } %>
              </div>
              <div class="leaderboard-info">
                <div class="leaderboard-name"><%= member.username %></div>
                <div class="leaderboard-stats"><span class="badge badge-purple">Lvl <%= member.level %></span> • <span class="xp-display"><%= member.xp.toLocaleString() %> XP</span></div>
              </div>
              <div class="leaderboard-progress">
                <div class="progress-bar"><div class="progress-fill" style="width: <%= (member.xp % 100) %>%"></div></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state"><i class="fa-solid fa-chart-line"></i><p>Aucune donnée d'XP disponible</p></div>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-gear"></i> Configuration XP</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/xp">
        <div class="toggle-row">
          <div><div class="toggle-label">Système XP activé</div><div class="toggle-sub">Les membres gagnent de l'XP en envoyant des messages</div></div>
          <label class="toggle"><input type="checkbox" name="enabled" <%= config?.xp?.enabled !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="divider"></div>

        <div class="form-group">
          <label class="form-label">XP par message</label>
          <input type="number" name="xpPerMessage" class="form-input" value="<%= config?.xp?.xpPerMessage || 15 %>" min="1" max="100">
          <div class="form-hint">Quantité d'XP attribuée par message (aléatoire ±5)</div>
        </div>

        <div class="form-group">
          <label class="form-label">Cooldown entre messages (secondes)</label>
          <input type="number" name="cooldown" class="form-input" value="<%= config?.xp?.cooldown || 60 %>" min="10" max="600">
          <div class="form-hint">Temps d'attente avant qu'un message suivant donne de l'XP</div>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Messages de niveau</div><div class="toggle-sub">Envoyer un message quand un membre gagne un niveau</div></div>
          <label class="toggle"><input type="checkbox" name="levelUpMessages" <%= config?.xp?.levelUpMessages !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <% if (config?.xp?.levelUpMessages !== false) { %>
          <div class="form-group">
            <label class="form-label">Salon des annonces de niveau</label>
            <select name="levelUpChannel" class="form-select">
              <option value="">— Salon actuel —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.xp?.levelUpChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Message personnalisé</label>
            <textarea name="levelUpMessage" class="form-textarea" rows="2" placeholder="Félicitations {user} ! Tu es maintenant niveau {level} 🎉"><%= config?.xp?.levelUpMessage || '' %></textarea>
            <div class="form-hint">Variables : {user}, {level}, {xp}</div>
          </div>
        <% } %>

        <div class="toggle-row">
          <div><div class="toggle-label">Ignorer les bots</div><div class="toggle-sub">Les bots ne gagnent pas d'XP</div></div>
          <label class="toggle"><input type="checkbox" name="ignoreBots" <%= config?.xp?.ignoreBots !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-gift"></i> Récompenses de niveau</div><div class="card-actions"><button class="btn btn-secondary btn-sm" onclick="addReward()"><i class="fa-solid fa-plus"></i> Ajouter</button></div></div>
      <div id="rewards-list">
        <% if (config?.xp?.rewards && config.xp.rewards.length > 0) { %>
          <% config.xp.rewards.forEach((reward, index) => { %>
            <div class="reward-item">
              <div class="reward-info">
                <div class="reward-label">Niveau <%= reward.level %></div>
                <div class="reward-role"><span class="badge badge-blue"><%= reward.roleName || reward.roleId %></span></div>
              </div>
              <button class="btn btn-danger btn-sm" onclick="removeReward(<%= index %>)"><i class="fa-solid fa-trash"></i></button>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state"><i class="fa-solid fa-gift"></i><p>Aucune récompense configurée</p></div>
        <% } %>
      </div>
    </div>
  </main>
</div>
<div id="toast"></div>
<script src="/js/main.js"></script>
<script>
function addReward() {
  showToast('Fonctionnalité en cours de développement', 'warning');
}
function removeReward(index) {
  if(confirm('Supprimer cette récompense ?')) {
    apiPost('/api/guild/<%= guild.id %>/xp/reward/delete', {index}).then(() => {
      showToast('Récompense supprimée', 'success');
      setTimeout(() => location.reload(), 1000);
    });
  }
}
</script>
<style>
.leaderboard {padding: 0;}
.leaderboard-item {display: flex; align-items: center; gap: 16px; padding: 16px; border-bottom: 1px solid var(--border-color); transition: all 0.2s;}
.leaderboard-item:last-child {border-bottom: none;}
.leaderboard-item:hover {background: rgba(124, 58, 237, 0.05);}
.leaderboard-rank {width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 700; font-size: 18px; background: var(--bg-hover);}
.leaderboard-rank.rank-1 {background: linear-gradient(135deg, #f59e0b, #d97706); color: #000;}
.leaderboard-rank.rank-2 {background: linear-gradient(135deg, #c0c0c0, #9ca3af); color: #000;}
.leaderboard-rank.rank-3 {background: linear-gradient(135deg, #cd7f32, #92400e); color: #fff;}
.leaderboard-avatar {width: 48px; height: 48px; border-radius: 50%; overflow: hidden;}
.leaderboard-avatar img {width: 100%; height: 100%; object-fit: cover;}
.avatar-placeholder {width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--accent-purple); color: #fff; font-weight: 700; font-size: 20px;}
.leaderboard-info {flex: 1;}
.leaderboard-name {font-weight: 600; font-size: 16px; color: var(--text-primary); margin-bottom: 4px;}
.leaderboard-stats {display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-secondary);}
.xp-display {color: var(--accent-purple); font-weight: 600;}
.leaderboard-progress {width: 120px;}
.progress-bar {height: 8px; background: var(--bg-hover); border-radius: 9999px; overflow: hidden;}
.progress-fill {height: 100%; background: linear-gradient(90deg, var(--accent-purple), var(--accent-gold)); border-radius: 9999px; transition: width 0.5s;}
.reward-item {display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--border-color);}
.reward-item:last-child {border-bottom: none;}
.reward-info {display: flex; align-items: center; gap: 12px;}
.reward-label {font-weight: 600; color: var(--text-primary);}
</style>
</body>
</html>
