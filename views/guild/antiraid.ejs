<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anti-Raid — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'antiraid' }) %>
  <main class="main-content with-sidebar">
    <div class="breadcrumb"><a href="/dashboard">Mes serveurs</a><span class="sep">›</span><a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span><span class="current">Anti-Raid</span></div>
    <div class="page-header"><h1><i class="fa-solid fa-user-shield"></i> Protection anti-raid</h1><p>Protégez votre serveur contre les attaques de raid</p></div>

    <div class="stats-grid grid-3">
      <div class="stat-card stat-card-purple">
        <div class="stat-icon"><i class="fa-solid fa-shield"></i></div>
        <div class="stat-info">
          <div class="stat-value"><%= config?.antiraid?.enabled ? 'Activé' : 'Désactivé' %></div>
          <div class="stat-label">Statut Anti-Raid</div>
        </div>
      </div>
      <div class="stat-card stat-card-blue">
        <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
        <div class="stat-info">
          <div class="stat-value"><%= config?.antiraid?.joinThreshold || 10 %></div>
          <div class="stat-label">Seuil de déclenchement</div>
        </div>
      </div>
      <div class="stat-card stat-card-red">
        <div class="stat-icon"><i class="fa-solid fa-clock"></i></div>
        <div class="stat-info">
          <div class="stat-value"><%= config?.antiraid?.timeWindow || 10 %>s</div>
          <div class="stat-label">Fenêtre temporelle</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-gear"></i> Configuration</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/antiraid">
        <div class="toggle-row">
          <div><div class="toggle-label">Anti-Raid activé</div><div class="toggle-sub">Active la protection automatique contre les raids</div></div>
          <label class="toggle"><input type="checkbox" name="enabled" <%= config?.antiraid?.enabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="divider"></div>

        <div class="form-group">
          <label class="form-label">Seuil de déclenchement (membres)</label>
          <input type="number" name="joinThreshold" class="form-input" value="<%= config?.antiraid?.joinThreshold || 10 %>" min="3" max="50">
          <div class="form-hint">Nombre de nouveaux membres qui déclenchent l'anti-raid</div>
        </div>

        <div class="form-group">
          <label class="form-label">Fenêtre temporelle (secondes)</label>
          <input type="number" name="timeWindow" class="form-input" value="<%= config?.antiraid?.timeWindow || 10 %>" min="5" max="60">
          <div class="form-hint">Durée pendant laquelle les arrivées sont comptées</div>
        </div>

        <div class="form-group">
          <label class="form-label">Action lors d'un raid</label>
          <select name="action" class="form-select">
            <option value="kick" <%= config?.antiraid?.action === 'kick' ? 'selected' : '' %>><i class="fa-solid fa-door-open"></i> Expulser les nouveaux membres</option>
            <option value="ban" <%= config?.antiraid?.action === 'ban' ? 'selected' : '' %>><i class="fa-solid fa-gavel"></i> Bannir les nouveaux membres</option>
            <option value="verify" <%= config?.antiraid?.action === 'verify' ? 'selected' : '' %>><i class="fa-solid fa-user-check"></i> Forcer la vérification</option>
            <option value="lockdown" <%= config?.antiraid?.action === 'lockdown' ? 'selected' : '' %>><i class="fa-solid fa-lock"></i> Verrouiller le serveur</option>
          </select>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Verrouillage automatique</div><div class="toggle-sub">Empêche les nouveaux messages pendant le raid</div></div>
          <label class="toggle"><input type="checkbox" name="lockdown" <%= config?.antiraid?.lockdown ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Notification des modérateurs</div><div class="toggle-sub">Mentionne les modérateurs lors d'un raid détecté</div></div>
          <label class="toggle"><input type="checkbox" name="notifyMods" <%= config?.antiraid?.notifyMods !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <div class="form-group">
          <label class="form-label">Salon de logs</label>
          <select name="logChannelId" class="form-select">
            <option value="">— Aucun salon —</option>
            <% textChannels.forEach(ch => { %>
              <option value="<%= ch.id %>" <%= config?.antiraid?.logChannelId === ch.id ? 'selected' : '' %>><%= ch.name %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-history"></i> Historique des raids</div></div>
      <% if (raidHistory && raidHistory.length > 0) { %>
        <table class="table">
          <thead><tr><th>Date</th><th>Membres</th><th>Action</th><th>Statut</th></tr></thead>
          <tbody>
            <% raidHistory.forEach(raid => { %>
              <tr>
                <td><%= new Date(raid.timestamp).toLocaleString('fr-FR') %></td>
                <td><%= raid.memberCount %> membres</td>
                <td><span class="badge badge-warning"><%= raid.action %></span></td>
                <td><span class="badge badge-<%= raid.resolved ? 'success' : 'danger' %>"><%= raid.resolved ? 'Résolu' : 'En cours' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state"><i class="fa-solid fa-shield-halved"></i><p>Aucun raid détecté</p></div>
      <% } %>
    </div>
  </main>
</div>
<div id="toast"></div>
<script src="/js/main.js"></script>
</body>
</html>
