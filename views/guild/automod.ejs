<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AutoMod — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'automod' }) %>
  <main class="main-content with-sidebar">
    <div class="breadcrumb"><a href="/dashboard">Mes serveurs</a><span class="sep">›</span><a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span><span class="current">AutoMod</span></div>
    <div class="page-header"><h1><i class="fa-solid fa-shield-halved"></i> Modération automatique</h1><p>Filtrez automatiquement les messages indésirables</p></div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-ban"></i> Filtres de contenu</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/automod">
        <div class="toggle-row">
          <div><div class="toggle-label">AutoMod activé (FastText ML)</div><div class="toggle-sub">Utilise le modèle IA FastText pour détecter les messages toxiques</div></div>
          <label class="toggle"><input type="checkbox" name="enabled" <%= config?.automod?.enabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="divider"></div>
        
        <div class="form-group">
          <label class="form-label">Mots interdits (Blacklist)</label>
          <textarea name="blacklist" class="form-textarea" rows="3" placeholder="mot1, mot2, mot3"><%= (config?.automod?.blacklist || []).join(', ') %></textarea>
          <div class="form-hint">Séparez les mots par des virgules. Détection insensible à la casse.</div>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Filtre MAJUSCULES</div><div class="toggle-sub">Supprime les messages avec trop de majuscules</div></div>
          <label class="toggle"><input type="checkbox" name="capsFilter" <%= config?.automod?.capsFilter ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.automod?.capsFilter) { %>
          <div class="form-group">
            <label class="form-label">Pourcentage max de majuscules</label>
            <input type="number" name="capsThreshold" class="form-input" value="<%= config?.automod?.capsThreshold || 70 %>" min="0" max="100">
          </div>
        <% } %>

        <div class="toggle-row">
          <div><div class="toggle-label">Anti-spam</div><div class="toggle-sub">Détecte les messages identiques répétés</div></div>
          <label class="toggle"><input type="checkbox" name="spamFilter" <%= config?.automod?.spamFilter ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.automod?.spamFilter) { %>
          <div class="form-group">
            <label class="form-label">Messages max en 10 secondes</label>
            <input type="number" name="spamThreshold" class="form-input" value="<%= config?.automod?.spamThreshold || 5 %>" min="1" max="20">
          </div>
        <% } %>

        <div class="toggle-row">
          <div><div class="toggle-label">Filtre liens</div><div class="toggle-sub">Bloque les liens HTTP/HTTPS non autorisés</div></div>
          <label class="toggle"><input type="checkbox" name="linkFilter" <%= config?.automod?.linkFilter ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Filtre emojis</div><div class="toggle-sub">Limite le nombre d'emojis par message</div></div>
          <label class="toggle"><input type="checkbox" name="emojiFilter" <%= config?.automod?.emojiFilter ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.automod?.emojiFilter) { %>
          <div class="form-group">
            <label class="form-label">Emojis max par message</label>
            <input type="number" name="emojiThreshold" class="form-input" value="<%= config?.automod?.emojiThreshold || 10 %>" min="1" max="50">
          </div>
        <% } %>

        <div class="toggle-row">
          <div><div class="toggle-label">Filtre mentions</div><div class="toggle-sub">Limite le nombre de mentions par message</div></div>
          <label class="toggle"><input type="checkbox" name="mentionFilter" <%= config?.automod?.mentionFilter ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.automod?.mentionFilter) { %>
          <div class="form-group">
            <label class="form-label">Mentions max par message</label>
            <input type="number" name="mentionThreshold" class="form-input" value="<%= config?.automod?.mentionThreshold || 5 %>" min="1" max="20">
          </div>
        <% } %>

        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>
  </main>
</div>
<div id="toast"></div>
<script src="/js/main.js"></script>
</body>
</html>
