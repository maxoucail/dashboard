<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IA — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'ai' }) %>
  <main class="main-content with-sidebar">

    <div class="breadcrumb">
      <a href="/dashboard">Mes serveurs</a><span class="sep">›</span>
      <a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span>
      <span class="current">Intelligence Artificielle</span>
    </div>

    <div class="page-header">
      <h1><i class="fa-solid fa-brain"></i> Intelligence Artificielle</h1>
      <p>Configurez le comportement de l'IA Chell sur ce serveur</p>
    </div>

    <%
      const ai = config?.ai_system || {};
      const aiEnabled = ai.enabled !== false;
      const personality = ai.personality || 'gentle';
      const blockedChannels = ai.blockedChannels || [];

      const personalities = [
        { value: 'gentle',     emoji: '✨', label: 'Gentille / Douce' },
        { value: 'spicy',      emoji: '🔥', label: 'Caractérielle' },
        { value: 'rick',       emoji: '🧪', label: 'Rick Sanchez' },
        { value: 'reddington', emoji: '🎩', label: 'Reddington' },
        { value: 'frista',     emoji: '🌀', label: 'Fresita' },
        { value: 'chill',      emoji: '😎', label: 'Mode Chill' },
        { value: 'productive', emoji: '⚡', label: 'Productivité' },
        { value: 'blala',      emoji: '🗣️', label: 'Blala Inutile' },
        { value: 'mirror',     emoji: '🪞', label: 'Miroir Sans Filtre' },
        { value: 'lucifer',    emoji: '😈', label: 'Lucifer' },
      ];
    %>

    <div class="grid-2">
      <!-- Statut global -->
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="fa-solid fa-power-off"></i> Statut global</div>
          <span class="badge <%= aiEnabled ? 'badge-green' : 'badge-red' %>">
            <%= aiEnabled ? '✅ Activée' : '❌ Désactivée' %>
          </span>
        </div>
        <div class="toggle-row">
          <div>
            <div class="toggle-label">IA Conversationnelle</div>
            <div class="toggle-sub">Active l'IA sur tous les salons non bloqués</div>
          </div>
          <label class="toggle">
            <input type="checkbox" id="ai-toggle" <%= aiEnabled ? 'checked' : '' %>
              data-api-toggle="/api/guild/<%= guild.id %>/ai" data-key="enabled">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="divider"></div>
        <div class="flex-between mt-16">
          <span class="text-muted text-small">Actions rapides :</span>
          <div class="flex gap-8">
            <button class="btn btn-danger btn-sm" onclick="toggleAllChannels(false, '<%= guild.id %>')">
              <i class="fa-solid fa-eye-slash"></i> Bloquer tout
            </button>
            <button class="btn btn-success btn-sm" onclick="toggleAllChannels(true, '<%= guild.id %>')">
              <i class="fa-solid fa-eye"></i> Débloquer tout
            </button>
          </div>
        </div>
      </div>

      <!-- Personnalité -->
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="fa-solid fa-masks-theater"></i> Personnalité</div>
        </div>
        <input type="hidden" id="personality-input" value="<%= personality %>">
        <div class="personality-grid">
          <% personalities.forEach(p => { %>
            <div class="personality-option <%= personality === p.value ? 'selected' : '' %>" data-value="<%= p.value %>">
              <span class="personality-emoji"><%= p.emoji %></span>
              <div class="personality-name"><%= p.label %></div>
            </div>
          <% }) %>
        </div>
        <button class="btn btn-primary w-full mt-16" onclick="savePersonality('<%= guild.id %>')">
          <i class="fa-solid fa-floppy-disk"></i> Sauvegarder la personnalité
        </button>
      </div>
    </div>

    <!-- Gestion des salons -->
    <div class="card mt-20">
      <div class="card-header">
        <div class="card-title"><i class="fa-solid fa-hashtag"></i> Salons — Accès IA</div>
        <div class="card-desc">Cliquez sur un salon pour le bloquer/débloquer</div>
      </div>
      <div class="channel-list" id="channel-list">
        <% textChannels.forEach(ch => { %>
          <div class="channel-item <%= blockedChannels.includes(ch.id) ? 'blocked' : '' %>"
            data-channel-id="<%= ch.id %>"
            data-guild-id="<%= guild.id %>">
            <span class="channel-hash">#</span>
            <span class="channel-name"><%= ch.name %></span>
            <span class="channel-badge">
              <% if (blockedChannels.includes(ch.id)) { %>
                <span class="badge badge-red">Bloqué</span>
              <% } %>
            </span>
          </div>
        <% }) %>
      </div>
    </div>

  </main>
</div>
<div id="toast"></div>
<script src="/js/main.js"></script>
<script>
async function savePersonality(guildId) {
  const val = document.getElementById('personality-input').value;
  const r = await apiPost(`/api/guild/${guildId}/ai`, { personality: val });
  if (r.success !== false) showToast('Personnalité sauvegardée !');
  else showToast('Erreur', 'error');
}

async function toggleAllChannels(allow, guildId) {
  const items = document.querySelectorAll('.channel-item');
  if (allow) {
    items.forEach(i => { i.classList.remove('blocked'); const b = i.querySelector('.channel-badge'); if(b) b.innerHTML = ''; });
    await apiPost(`/api/guild/${guildId}/ai`, { blockedChannels: [] });
    showToast('Tous les salons débloqués !');
  } else {
    const ids = [];
    items.forEach(i => {
      i.classList.add('blocked');
      const b = i.querySelector('.channel-badge');
      if(b) b.innerHTML = '<span class="badge badge-red">Bloqué</span>';
      ids.push(i.getAttribute('data-channel-id'));
    });
    await apiPost(`/api/guild/${guildId}/ai`, { blockedChannels: ids });
    showToast('Tous les salons bloqués !');
  }
}
</script>
</body>
</html>
