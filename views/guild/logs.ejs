<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logs — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'logs' }) %>
  <main class="main-content with-sidebar">
    <div class="breadcrumb"><a href="/dashboard">Mes serveurs</a><span class="sep">›</span><a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span><span class="current">Logs</span></div>
    <div class="page-header"><h1><i class="fa-solid fa-file-lines"></i> Système de logs</h1><p>Enregistrez les événements importants du serveur</p></div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-shield-halved"></i> Logs de modération</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Logs de modération activés</div><div class="toggle-sub">Warns, bans, kicks, timeouts, mutes</div></div>
          <label class="toggle"><input type="checkbox" name="modLogsEnabled" <%= config?.logs?.modLogsEnabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.logs?.modLogsEnabled) { %>
          <div class="form-group">
            <label class="form-label">Salon des logs de modération</label>
            <select name="modLogsChannel" class="form-select">
              <option value="">— Sélectionner un salon —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.logs?.modLogsChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-users"></i> Logs des membres</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Logs des membres activés</div><div class="toggle-sub">Arrivées, départs, changements de pseudo/rôles</div></div>
          <label class="toggle"><input type="checkbox" name="memberLogsEnabled" <%= config?.logs?.memberLogsEnabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.logs?.memberLogsEnabled) { %>
          <div class="form-group">
            <label class="form-label">Salon des logs des membres</label>
            <select name="memberLogsChannel" class="form-select">
              <option value="">— Sélectionner un salon —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.logs?.memberLogsChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-message"></i> Logs des messages</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Logs des messages activés</div><div class="toggle-sub">Messages supprimés, édités, épinglés</div></div>
          <label class="toggle"><input type="checkbox" name="messageLogsEnabled" <%= config?.logs?.messageLogsEnabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.logs?.messageLogsEnabled) { %>
          <div class="form-group">
            <label class="form-label">Salon des logs des messages</label>
            <select name="messageLogsChannel" class="form-select">
              <option value="">— Sélectionner un salon —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.logs?.messageLogsChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-volume-high"></i> Logs vocaux</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Logs vocaux activés</div><div class="toggle-sub">Entrées/sorties des salons vocaux</div></div>
          <label class="toggle"><input type="checkbox" name="voiceLogsEnabled" <%= config?.logs?.voiceLogsEnabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.logs?.voiceLogsEnabled) { %>
          <div class="form-group">
            <label class="form-label">Salon des logs vocaux</label>
            <select name="voiceLogsChannel" class="form-select">
              <option value="">— Sélectionner un salon —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.logs?.voiceLogsChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-server"></i> Logs du serveur</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Logs du serveur activés</div><div class="toggle-sub">Création/suppression de salons, rôles, emojis</div></div>
          <label class="toggle"><input type="checkbox" name="serverLogsEnabled" <%= config?.logs?.serverLogsEnabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <% if (config?.logs?.serverLogsEnabled) { %>
          <div class="form-group">
            <label class="form-label">Salon des logs du serveur</label>
            <select name="serverLogsChannel" class="form-select">
              <option value="">— Sélectionner un salon —</option>
              <% textChannels.forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config?.logs?.serverLogsChannel === ch.id ? 'selected' : '' %>><%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-sliders"></i> Options avancées</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/logs">
        <div class="toggle-row">
          <div><div class="toggle-label">Ignorer les bots</div><div class="toggle-sub">Ne pas logger les actions des bots</div></div>
          <label class="toggle"><input type="checkbox" name="ignoreBots" <%= config?.logs?.ignoreBots !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Logs détaillés</div><div class="toggle-sub">Afficher plus d'informations dans les embeds</div></div>
          <label class="toggle"><input type="checkbox" name="detailedLogs" <%= config?.logs?.detailedLogs ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Avatar dans les embeds</div><div class="toggle-sub">Afficher l'avatar de l'utilisateur concerné</div></div>
          <label class="toggle"><input type="checkbox" name="showAvatars" <%= config?.logs?.showAvatars !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>
  </main>
</div>
<div id="toast"></div>
<script src="/js/main.js"></script>
</body>
</html>
