<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Réseaux Sociaux — <%= guild.name %></title>
  <link rel="icon" href="/img/chell-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="layout">
  <%- include('../partials/sidebar', { guild, guildId: guild.id, activePage: 'social' }) %>
  <main class="main-content with-sidebar">
    <div class="breadcrumb"><a href="/dashboard">Mes serveurs</a><span class="sep">›</span><a href="/guild/<%= guild.id %>"><%= guild.name %></a><span class="sep">›</span><span class="current">Réseaux Sociaux</span></div>
    <div class="page-header"><h1><i class="fa-brands fa-twitter"></i> Flux RSS & Réseaux sociaux</h1><p>Suivez automatiquement Twitter, YouTube, Twitch et flux RSS</p></div>

    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fa-solid fa-rss"></i> Flux RSS actifs</div>
        <button class="btn btn-sm btn-secondary" onclick="showAddFeedModal()"><i class="fa-solid fa-plus"></i> Ajouter un flux</button>
      </div>
      <div class="feeds-list">
        <% if (config?.social?.feeds && config.social.feeds.length > 0) { %>
          <% config.social.feeds.forEach((feed, idx) => { %>
            <div class="feed-item">
              <div class="feed-icon">
                <% if (feed.type === 'twitter') { %>
                  <i class="fa-brands fa-twitter"></i>
                <% } else if (feed.type === 'youtube') { %>
                  <i class="fa-brands fa-youtube"></i>
                <% } else if (feed.type === 'twitch') { %>
                  <i class="fa-brands fa-twitch"></i>
                <% } else { %>
                  <i class="fa-solid fa-rss"></i>
                <% } %>
              </div>
              <div class="feed-info">
                <div class="feed-name"><%= feed.name || feed.url %></div>
                <div class="feed-details">
                  <span class="feed-type"><%= feed.type %></span>
                  <span class="feed-channel"><i class="fa-solid fa-hashtag"></i><%= textChannels.find(c => c.id === feed.channelId)?.name || feed.channelId %></span>
                  <span class="feed-interval"><i class="fa-solid fa-clock"></i><%= feed.interval || 5 %> min</span>
                </div>
              </div>
              <div class="feed-status">
                <span class="badge <%= feed.enabled !== false ? 'badge-success' : 'badge-secondary' %>"><%= feed.enabled !== false ? 'Actif' : 'Pausé' %></span>
              </div>
              <div class="feed-actions">
                <button class="btn btn-sm btn-secondary" onclick="toggleFeed(<%= idx %>)"><i class="fa-solid fa-<%= feed.enabled !== false ? 'pause' : 'play' %>"></i></button>
                <button class="btn btn-sm btn-danger" onclick="deleteFeed(<%= idx %>)"><i class="fa-solid fa-trash"></i></button>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state"><i class="fa-solid fa-rss"></i><div>Aucun flux configuré</div><div class="empty-hint">Ajoutez un flux RSS, Twitter, YouTube ou Twitch pour commencer</div></div>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fa-solid fa-cog"></i> Configuration globale</div></div>
      <form data-api-form="/api/guild/<%= guild.id %>/social">
        <div class="toggle-row">
          <div><div class="toggle-label">Flux RSS activés</div><div class="toggle-sub">Récupération automatique des nouveaux contenus</div></div>
          <label class="toggle"><input type="checkbox" name="enabled" <%= config?.social?.enabled !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>
        <div class="divider"></div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Intervalle par défaut (minutes)</label>
            <input type="number" name="defaultInterval" class="form-input" min="1" max="60" value="<%= config?.social?.defaultInterval || 5 %>">
            <div class="form-hint">Fréquence de vérification des nouveaux contenus</div>
          </div>
          <div class="form-group">
            <label class="form-label">Format des messages</label>
            <select name="messageFormat" class="form-select">
              <option value="embed" <%= config?.social?.messageFormat !== 'text' ? 'selected' : '' %>>📋 Embed</option>
              <option value="text" <%= config?.social?.messageFormat === 'text' ? 'selected' : '' %>>📝 Texte simple</option>
            </select>
          </div>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Inclure les images</div><div class="toggle-sub">Afficher les miniatures et images dans les embeds</div></div>
          <label class="toggle"><input type="checkbox" name="includeImages" <%= config?.social?.includeImages !== false ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <div class="toggle-row">
          <div><div class="toggle-label">Notifications @everyone</div><div class="toggle-sub">Mentionner @everyone pour les nouvelles publications</div></div>
          <label class="toggle"><input type="checkbox" name="mentionEveryone" <%= config?.social?.mentionEveryone ? 'checked' : '' %>><span class="toggle-slider"></span></label>
        </div>

        <button type="submit" class="btn btn-primary w-full mt-16"><i class="fa-solid fa-floppy-disk"></i> Sauvegarder</button>
      </form>
    </div>
  </main>
</div>

<!-- Modal Add Feed -->
<div id="addFeedModal" class="modal" style="display: none;">
  <div class="modal-content">
    <div class="modal-header"><h2>Ajouter un flux</h2><button class="modal-close" onclick="closeAddFeedModal()"><i class="fa-solid fa-times"></i></button></div>
    <div class="modal-body">
      <form id="addFeedForm">
        <div class="form-group">
          <label class="form-label">Type de flux</label>
          <select name="type" class="form-select" onchange="updateFeedForm(this.value)">
            <option value="rss">RSS Feed</option>
            <option value="twitter">Twitter/X</option>
            <option value="youtube">YouTube</option>
            <option value="twitch">Twitch</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">URL ou Identifiant</label>
          <input type="text" name="url" class="form-input" placeholder="https://example.com/feed.xml">
          <div class="form-hint" id="urlHint">URL du flux RSS</div>
        </div>
        <div class="form-group">
          <label class="form-label">Nom du flux (optionnel)</label>
          <input type="text" name="name" class="form-input" placeholder="Mon flux">
        </div>
        <div class="form-group">
          <label class="form-label">Salon de destination</label>
          <select name="channelId" class="form-select">
            <% textChannels.forEach(ch => { %>
              <option value="<%= ch.id %>"><%= ch.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Intervalle (minutes)</label>
          <input type="number" name="interval" class="form-input" min="1" max="60" value="5">
        </div>
        <button type="button" class="btn btn-primary w-full" onclick="submitAddFeed()"><i class="fa-solid fa-plus"></i> Ajouter le flux</button>
      </form>
    </div>
  </div>
</div>

<div id="toast"></div>
<script src="/js/main.js"></script>
<script>
function showAddFeedModal() {
  document.getElementById('addFeedModal').style.display = 'flex';
}
function closeAddFeedModal() {
  document.getElementById('addFeedModal').style.display = 'none';
}
function updateFeedForm(type) {
  const hints = {
    rss: 'URL du flux RSS',
    twitter: 'Nom d\'utilisateur Twitter (sans @)',
    youtube: 'URL de la chaîne ou identifiant',
    twitch: 'Nom de la chaîne Twitch'
  };
  document.getElementById('urlHint').textContent = hints[type] || 'URL du flux';
}
function submitAddFeed() {
  const form = document.getElementById('addFeedForm');
  const data = Object.fromEntries(new FormData(form));
  apiPost(`/api/guild/<%= guild.id %>/social/feed`, data)
    .then(() => {
      showToast('Flux ajouté avec succès', 'success');
      setTimeout(() => location.reload(), 1000);
    });
}
function toggleFeed(idx) {
  apiPost(`/api/guild/<%= guild.id %>/social/feed/${idx}/toggle`, {})
    .then(() => {
      showToast('Statut du flux modifié', 'success');
      setTimeout(() => location.reload(), 800);
    });
}
function deleteFeed(idx) {
  if (confirm('Supprimer ce flux ?')) {
    apiPost(`/api/guild/<%= guild.id %>/social/feed/${idx}/delete`, {})
      .then(() => {
        showToast('Flux supprimé', 'success');
        setTimeout(() => location.reload(), 800);
      });
  }
}
</script>
</body>
</html>
